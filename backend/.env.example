# IBMI Backend - variáveis de ambiente
# Copiar para .env e ajustar

PROJECT_NAME=IBMI - Agenda Igrejas
API_V1_STR=/api/v1

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ibmi
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
DEBUG=false
