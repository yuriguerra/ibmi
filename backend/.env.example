# ─── Banco de Dados ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ibmi:ibmi@db:5432/ibmi

# ─── Segurança ────────────────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-secrets-token-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Aplicação ────────────────────────────────────────────────────────────────
PROJECT_NAME=IBMI - Agenda Igrejas
VERSION=0.1.0
API_V1_STR=/api/v1
DEBUG=false
PYTHONPATH=.


# ─── CORS ─────────────────────────────────────────────────────────────────────
# Separar múltiplas origens com vírgula (sem espaço)
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
